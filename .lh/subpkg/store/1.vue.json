            "date": 1748938599422,
            "name": "Commit-0",
            "content": "<template>\r\n  <div class=\"store\">\r\n    <uni-forms\r\n      ref=\"baseForm\"\r\n      :modelValue=\"formData\"\r\n      style=\"padding: 30rpx\"\r\n      :rules=\"rules\"\r\n    >\r\n      <uni-forms-item label=\"装备类型\" name=\"kind\" required label-width=\"90\">\r\n        <uni-data-select\r\n          v-model=\"formData.kind\"\r\n          :localdata=\"range\"\r\n          :clear=\"false\"\r\n        ></uni-data-select>\r\n      </uni-forms-item>\r\n      <uni-forms-item label=\"装备名称\" name=\"name\" required label-width=\"90\">\r\n        <uni-easyinput\r\n          type=\"text\"\r\n          v-model=\"formData.name\"\r\n          placeholder=\"请输入装备名称\"\r\n          :clearable=\"false\"\r\n        />\r\n      </uni-forms-item>\r\n      <uni-forms-item label=\"型号规格\" name=\"spec\" required label-width=\"90\">\r\n        <uni-easyinput\r\n          type=\"text\"\r\n          v-model=\"formData.spec\"\r\n          placeholder=\"请输入型号规格\"\r\n          :clearable=\"false\"\r\n        />\r\n      </uni-forms-item>\r\n      <uni-forms-item label=\"负责人\" name=\"principal_name\" required>\r\n        <uni-data-select\r\n          v-model=\"formData.principal_name\"\r\n          :localdata=\"staffList\"\r\n          @change=\"change2\"\r\n          :clear=\"false\"\r\n        ></uni-data-select>\r\n      </uni-forms-item>\r\n      <uni-forms-item label=\"失效日期\" name=\"expire_date\" label-width=\"90\">\r\n        <uni-datetime-picker\r\n          type=\"date\"\r\n          :value=\"formData.expire_date\"\r\n          @change=\"changesx\"\r\n          :clear-icon=\"false\"\r\n        />\r\n      </uni-forms-item>\r\n      <uni-forms-item\r\n        label=\"维保日期\"\r\n        name=\"maintenance_date\"\r\n        required\r\n        label-width=\"90\"\r\n      >\r\n        <uni-datetime-picker\r\n          type=\"date\"\r\n          :value=\"formData.maintenance_date\"\r\n          @change=\"changewb\"\r\n          :clear-icon=\"false\"\r\n        />\r\n      </uni-forms-item>\r\n      <uni-forms-item label=\"装备数量\" name=\"count\" required label-width=\"90\">\r\n        <uni-easyinput\r\n          type=\"number\"\r\n          v-model=\"formData.count\"\r\n          placeholder=\"请输入装备数量\"\r\n          :clearable=\"false\"\r\n        />\r\n      </uni-forms-item>\r\n      <view v-for=\"(item, index) in formData.rfid_code\" :key=\"index\">\r\n        <uni-forms-item\r\n          :label=\"'RFID编号' + (index + 1)\"\r\n          :name=\"'rfid_' + index\"\r\n          label-width=\"90\"\r\n          required\r\n        >\r\n          <uni-easyinput\r\n            v-model=\"formData.rfid_code[index]\"\r\n            placeholder=\"请输入RFID编号\"\r\n            :clearable=\"false\"\r\n          />\r\n        </uni-forms-item>\r\n      </view>\r\n    </uni-forms>\r\n    <view class=\"btns1\" @click=\"subBtn('baseForm')\">提交</view>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { staff, equipmentNew } from '@/api/api.js';\r\nexport default {\r\n  data() {\r\n    return {\r\n      formData: {\r\n        kind: '',\r\n        name: '',\r\n        spec: '',\r\n        principal_id: '',\r\n        expire_date: undefined,\r\n        count: '',\r\n        maintenance_date: '',\r\n        rfid_code: [],\r\n      },\r\n      rule: '',\r\n      range: [\r\n        { value: 1, text: '随车装备' },\r\n        { value: 2, text: '抢险救援装备' },\r\n        { value: 3, text: '个人防护装备' },\r\n      ],\r\n      rules: {\r\n        kind: {\r\n          rules: [\r\n            {\r\n              required: true,\r\n              errorMessage: '请选择装备类型',\r\n            },\r\n          ],\r\n        },\r\n        name: {\r\n          rules: [\r\n            {\r\n              required: true,\r\n              errorMessage: '请输入装备名称',\r\n            },\r\n          ],\r\n        },\r\n        spec: {\r\n          rules: [\r\n            {\r\n              required: true,\r\n              errorMessage: '请输入型号规格',\r\n            },\r\n          ],\r\n        },\r\n        principal_name: {\r\n          rules: [\r\n            {\r\n              required: true,\r\n              errorMessage: '请选择负责人',\r\n            },\r\n          ],\r\n        },\r\n        count: {\r\n          rules: [\r\n            {\r\n              required: true,\r\n              errorMessage: '请输入装备数量',\r\n            },\r\n          ],\r\n        },\r\n      },\r\n      staffList: [],\r\n      currentIndex: 0,\r\n    };\r\n  },\r\n\r\n  created() {\r\n    this.getStaff();\r\n  },\r\n  watch: {\r\n    'formData.count'(newCount) {\r\n      const count = parseInt(newCount) || 0;\r\n      if (count > this.formData.rfid_code.length) {\r\n        // 增加空位\r\n        for (let i = this.formData.rfid_code.length; i < count; i++) {\r\n          this.formData.rfid_code.push('');\r\n        }\r\n      } else {\r\n        // 减少多余项\r\n        this.formData.rfid_code.splice(count);\r\n      }\r\n    },\r\n  },\r\n  methods: {\r\n    //获取人员信息\r\n    async getStaff() {\r\n      const res = await staff({\r\n        limit: 200,\r\n      });\r\n      this.staffList = res.data.list.filter((data) => data.enable != 0);\r\n      this.staffList = this.staffList.map((item) => ({\r\n        value: item.uid,\r\n        text: item.name,\r\n      }));\r\n    },\r\n    change2(e) {\r\n      this.formData.principal_id = e;\r\n    },\r\n    //点击提交入库\r\n    async subBtn(ref) {\r\n      this.$refs[ref].validate().then(async () => {\r\n        const data = {\r\n          kind: this.formData.kind,\r\n          name: this.formData.name,\r\n          spec: this.formData.spec,\r\n          principal_id: this.formData.principal_id,\r\n          expire_date: this.formData.expire_date,\r\n          maintenance_date: this.formData.maintenance_date,\r\n          count: this.formData.count,\r\n          rfid_code: this.formData.rfid_code,\r\n        };\r\n        try {\r\n          const res = await equipmentNew(data);\r\n          if (res.code === 0) {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: '添加设备成功',\r\n              duration: 1000,\r\n            });\r\n            setTimeout(() => {\r\n              uni.reLaunch({\r\n                url: '/pages/index/index',\r\n              });\r\n            }, 1000);\r\n          } else {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: res.msg,\r\n            });\r\n          }\r\n        } catch (err) {\r\n          uni.showToast({\r\n            icon: 'none',\r\n            title: err,\r\n          });\r\n        }\r\n      });\r\n    },\r\n    changesx(val) {\r\n      this.formData.expire_date = val;\r\n    },\r\n    changewb(val) {\r\n      this.formData.maintenance_date = val;\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped lang=\"scss\">\r\n.btns1 {\r\n  width: 90%;\r\n  height: 70rpx;\r\n  background-color: #ff8400;\r\n  border-radius: 15rpx;\r\n  text-align: center;\r\n  line-height: 70rpx;\r\n  color: #fff;\r\n  margin: 20rpx auto;\r\n}\r\n::v-deep .uni-datetime-picker--btn {\r\n  background-color: #ff8400;\r\n}\r\n::v-deep .uni-calendar-item--checked {\r\n  background-color: #ff8400 !important;\r\n}\r\n</style>\r\n"
        }
    ]
}