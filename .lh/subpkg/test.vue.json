             label-width=\"90\"\r\n            >\r\n              <uni-easyinput\r\n                v-model=\"formData3.maintenance_date\"\r\n                placeholder=\"请输入维保日期\"\r\n                :clearable=\"false\"\r\n                :disabled=\"true\"\r\n              />\r\n            </uni-forms-item>\r\n          </uni-forms>\r\n          <view class=\"btns1\" @click=\"iszbcheckNew\">确认</view>\r\n        </view>\r\n      </uni-popup>\r\n      <uni-popup ref=\"popup12\" background-color=\"#fff\" style=\"width: 160vw\">\r\n        <view class=\"ruku-title\">装备详情</view>\r\n        <div style=\"width: 100%; height: 1px\"></div>\r\n        <uni-forms\r\n          ref=\"baseForm\"\r\n          :modelValue=\"formData4\"\r\n          style=\"padding: 0 30rpx; margin-top: 30rpx\"\r\n        >\r\n          <uni-forms-item label=\"结果\" name=\"result\" required label-width=\"90\">\r\n            <uni-data-select\r\n              v-model=\"formData4.result\"\r\n              :localdata=\"rangeResult\"\r\n              :clear=\"false\"\r\n            ></uni-data-select>\r\n          </uni-forms-item>\r\n          <uni-forms-item\r\n            label=\"失效日期\"\r\n            name=\"expire_date\"\r\n            required\r\n            label-width=\"90\"\r\n          >\r\n            <uni-datetime-picker\r\n              type=\"date\"\r\n              :value=\"formData4.expire_date\"\r\n              @change=\"changeResult\"\r\n              :clear-icon=\"false\"\r\n            />\r\n          </uni-forms-item>\r\n        </uni-forms>\r\n        <view class=\"btns1\" @click=\"iszbcheckNew2\">确认</view>\r\n      </uni-popup>\r\n    </view>\r\n  </template>\r\n  <script>\r\n  import {\r\n    equipmentNew,\r\n    staff,\r\n    equipmentCheck,\r\n    receive,\r\n    receiveCheck,\r\n    receiveConfirm,\r\n    returnCheck,\r\n    returnConfirm,\r\n    receiveSelect,\r\n    equipmentList,\r\n    equipmentAdd,\r\n    equipmentDetail,\r\n    equipmentItemGet,\r\n  } from '@/api/api.js';\r\n  export default {\r\n    data() {\r\n      return {\r\n        formData3: {},\r\n        rangecheck: [],\r\n        formData1: {\r\n          rfid_code: [],\r\n          equimentName: '',\r\n        },\r\n        formData2: {\r\n          rfid_code: [],\r\n          equimentName: '',\r\n        },\r\n        formData4: {\r\n          result: '',\r\n          expire_date: '',\r\n        },\r\n        rangeResult: [\r\n          { value: 1, text: '正常' },\r\n          { value: 2, text: '损坏' },\r\n        ],\r\n        equipmentId: '',\r\n        receives: '',\r\n        lyUid: '',\r\n        ghUid: '',\r\n        ghReturn: '',\r\n        pd: {\r\n          column: [\r\n            {\r\n              name: 'name',\r\n              label: '名称',\r\n              fixed: true,\r\n              width: 60,\r\n              emptyString: '--',\r\n              align: 'center',\r\n            },\r\n            {\r\n              name: 'kind',\r\n              label: '类型',\r\n              sorter: false,\r\n              align: 'center',\r\n              width: 80,\r\n            },\r\n            { name: 'spec', label: '规格', width: 80, align: 'center' },\r\n            {\r\n              name: 'count',\r\n              label: '数量',\r\n              sorter: true,\r\n              width: 140,\r\n              align: 'center',\r\n            },\r\n            {\r\n              name: 'operation',\r\n              type: 'operation',\r\n              label: '操作',\r\n              fixed: true,\r\n              align: 'center',\r\n              renders: [\r\n                {\r\n                  name: '核检',\r\n                  func: 'edit', // func 代表子元素点击的事件 父元素接收的事件 父元素 @edit\r\n                },\r\n                // {\r\n                //   name: '详情',\r\n                //   type: 'primary', // type 为custom的时候自定义按钮\r\n                //   class: 'del',\r\n                //   func: 'dele',\r\n                // },\r\n              ],\r\n            },\r\n          ],\r\n          data: [],\r\n        },\r\n        gh: {\r\n          column: [\r\n            {\r\n              name: 'receiver_name',\r\n              label: '领用人',\r\n              fixed: true,\r\n              width: 80,\r\n              emptyString: '--',\r\n              align: 'center',\r\n            },\r\n            {\r\n              name: 'situation',\r\n              label: '情况',\r\n              sorter: false,\r\n              align: 'center',\r\n              width: 80,\r\n            },\r\n            {\r\n              name: 'receive_date',\r\n              label: '领用日期',\r\n              width: 120,\r\n              align: 'center',\r\n            },\r\n            {\r\n              name: 'operation',\r\n              type: 'operation',\r\n              label: '操作',\r\n              fixed: true,\r\n              align: 'center',\r\n              renders: [\r\n                {\r\n                  name: '归还',\r\n                  func: 'edit', // func 代表子元素点击的事件 父元素接收的事件 父元素 @edit\r\n                },\r\n              ],\r\n            },\r\n          ],\r\n          data: [],\r\n        },\r\n        ly: {\r\n          column: [\r\n            {\r\n              name: 'receiver_name',\r\n              label: '领用人',\r\n              fixed: true,\r\n              width: 80,\r\n              emptyString: '--',\r\n              align: 'center',\r\n            },\r\n            {\r\n              name: 'organization_name',\r\n              label: '组织名称',\r\n              sorter: false,\r\n              align: 'center',\r\n              width: 90,\r\n            },\r\n            {\r\n              name: 'situation',\r\n              label: '情况',\r\n              sorter: false,\r\n              align: 'center',\r\n              width: 80,\r\n            },\r\n            {\r\n              name: 'receive_date',\r\n              label: '领用日期',\r\n              width: 90,\r\n              align: 'center',\r\n            },\r\n            {\r\n              name: 'operation',\r\n              type: 'operation',\r\n              label: '操作',\r\n              fixed: true,\r\n              align: 'center',\r\n              renders: [\r\n                {\r\n                  name: '扫描',\r\n                  func: 'edit', // func 代表子元素点击的事件 父元素接收的事件 父元素 @edit\r\n                },\r\n              ],\r\n            },\r\n          ],\r\n          data: [],\r\n        },\r\n        loading: false,\r\n        infos: {},\r\n        formData: {\r\n          kind: '',\r\n          name: '',\r\n          spec: '',\r\n          principal_id: '',\r\n          expire_date: undefined,\r\n          count: '',\r\n          maintenance_date: '',\r\n          rfid_code: [],\r\n        },\r\n        rule: '',\r\n        range: [\r\n          { value: 1, text: '侦检' },\r\n          { value: 2, text: '警戒' },\r\n          { value: 3, text: '破拆' },\r\n          { value: 4, text: '堵漏' },\r\n          { value: 5, text: '输转' },\r\n          { value: 6, text: '其他' },\r\n        ],\r\n        rules: {\r\n          kind: {\r\n            rules: [\r\n              {\r\n                required: true,\r\n                errorMessage: '请选择装备类型',\r\n              },\r\n            ],\r\n          },\r\n          name: {\r\n            rules: [\r\n              {\r\n                required: true,\r\n                errorMessage: '请输入装备名称',\r\n              },\r\n            ],\r\n          },\r\n          spec: {\r\n            rules: [\r\n              {\r\n                required: true,\r\n                errorMessage: '请输入型号规格',\r\n              },\r\n            ],\r\n          },\r\n          principal_name: {\r\n            rules: [\r\n              {\r\n                required: true,\r\n                errorMessage: '请选择负责人',\r\n              },\r\n            ],\r\n          },\r\n          count: {\r\n            rules: [\r\n              {\r\n                required: true,\r\n                errorMessage: '请输入装备数量',\r\n              },\r\n            ],\r\n          },\r\n        },\r\n        staffList: '',\r\n      };\r\n    },\r\n    created() {\r\n      this.infos = uni.getStorageSync('infos');\r\n      this.getStaff();\r\n      this.getreceiveSelect();\r\n      this.getEquipment();\r\n    },\r\n    watch: {\r\n      'formData.count'(newCount) {\r\n        const count = parseInt(newCount) || 0;\r\n        if (count > this.formData.rfid_code.length) {\r\n          // 增加空位\r\n          for (let i = this.formData.rfid_code.length; i < count; i++) {\r\n            this.formData.rfid_code.push('');\r\n          }\r\n        } else {\r\n          // 减少多余项\r\n          this.formData.rfid_code.splice(count);\r\n        }\r\n      },\r\n    },\r\n    methods: {\r\n      //获取装备列表   //申请领用的时候不能重复，需要排除掉\r\n      async getEquipment() {\r\n        const res = await equipmentList({\r\n          limit: 100,\r\n        });\r\n        this.pd.data = res.data.list;\r\n        this.rangecheck = this.pd.data.map((item) => ({\r\n          value: item.uid,\r\n          text: item.name,\r\n        }));\r\n      },\r\n      changeFn(e) {\r\n        console.log(e, 'e');\r\n        let arr = this.pd.data.filter((item) => {\r\n          return item.uid === e;\r\n        });\r\n        if (arr.length > 0) {\r\n          const count = arr[0].count;\r\n  \r\n          // 初始化 formData1.rfid_code 为指定长度的数组\r\n          this.formData1.rfid_code = Array.from({ length: count }, () => '');\r\n        }\r\n      },\r\n      //获取人员信息\r\n      async getStaff() {\r\n        const res = await staff({\r\n          limit: 200,\r\n        });\r\n        this.staffList = res.data.list.filter((data) => data.enable != 0);\r\n        this.staffList = this.staffList.map((item) => ({\r\n          value: item.uid,\r\n          text: item.name,\r\n        }));\r\n      },\r\n      //获取领用列表\r\n      async getreceive() {\r\n        const res = await receive({\r\n          limit: 100,\r\n        });\r\n        if (res.data) {\r\n          this.ly.data = res.data.list;\r\n          this.ly.data.forEach((item) => {\r\n            if (item.situation === 1) {\r\n              item.situation = '紧急';\r\n            } else {\r\n              item.situation = '非紧急';\r\n            }\r\n          });\r\n          this.ly.data = this.ly.data.filter(\r\n            (item) => item.situation != '非紧急'\r\n          );\r\n        } else {\r\n          this.ly.data = [];\r\n        }\r\n      },\r\n      //获取领用选择列表\r\n      async getreceiveSelect() {\r\n        const res = await receiveSelect({\r\n          limit: 100,\r\n        });\r\n        if (res.data) {\r\n          this.gh.data = res.data.list;\r\n          this.gh.data.forEach((item) => {\r\n            if (item.situation == 1) {\r\n              item.situation = '紧急';\r\n            } else {\r\n              item.situation = '非紧急';\r\n            }\r\n          });\r\n        } else {\r\n          this.gh.data = [];\r\n        }\r\n      },\r\n      //获取装备详情\r\n      async getEquipmentDetail() {\r\n        const res = await equipmentDetail({ uid: this.equipmentId });\r\n        this.equDetail = res.data;\r\n      },\r\n      change2(e) {\r\n        this.formData.principal_id = e;\r\n      },\r\n      //领用\r\n      isLy() {\r\n        // this.$refs.popup1.open();\r\n        // this.getreceive();\r\n        uni.navigateTo({\r\n          url: '/subpkg/neck/index',\r\n        });\r\n      },\r\n      //入库\r\n      isRk() {\r\n        // uni.chooseImage({\r\n        //   count: 1,\r\n        //   success: (res) => {\r\n        // this.$refs.popup2.open();\r\n        //   },\r\n        //   fail: (res) => {\r\n        //     console.log(res, 'faail');\r\n        //   },\r\n        // });\r\n        uni.navigateTo({\r\n          url: '/subpkg/store/index',\r\n        });\r\n      },\r\n      //归还\r\n      isGh() {\r\n        // this.$refs.popup3.open();\r\n        uni.navigateTo({\r\n          url: '/subpkg/turn/index',\r\n        });\r\n      },\r\n      //盘点\r\n      isPd() {\r\n        // this.$refs.popup4.open();\r\n        uni.navigateTo({\r\n          url: '/subpkg/stocktaking/index',\r\n        });\r\n      },\r\n      //点击操作按钮\r\n      chooseImg() {\r\n        uni.chooseImage({\r\n          count: 1,\r\n          success: (res) => {\r\n            console.log(res, 'res');\r\n          },\r\n          fail: (res) => {\r\n            console.log(res, 'faail');\r\n          },\r\n        });\r\n      },\r\n      changesx(val) {\r\n        this.formData.expire_date = val;\r\n      },\r\n      changewb(val) {\r\n        this.formData.maintenance_date = val;\r\n      },\r\n      changeResult(val) {\r\n        this.formData4.expire_date = val;\r\n      },\r\n      //点击提交入库\r\n      async subBtn(ref) {\r\n        this.$refs[ref].validate().then(async () => {\r\n          const data = {\r\n            kind: this.formData.kind,\r\n            name: this.formData.name,\r\n            spec: this.formData.spec,\r\n            principal_id: this.formData.principal_id,\r\n            expire_date: this.formData.expire_date,\r\n            maintenance_date: this.formData.maintenance_date,\r\n            count: this.formData.count,\r\n            rfid_code: this.formData.rfid_code,\r\n          };\r\n          try {\r\n            const res = await equipmentNew(data);\r\n            if (res.code === 0) {\r\n              uni.showToast({\r\n                icon: 'none',\r\n                title: '添加设备成功',\r\n                duration: 1000,\r\n              });\r\n              this.$refs.popup2.close();\r\n            } else {\r\n              uni.showToast({\r\n                icon: 'none',\r\n                title: res.msg,\r\n              });\r\n            }\r\n          } catch (err) {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: err,\r\n            });\r\n          }\r\n        });\r\n      },\r\n      async buttonEdit4(e) {\r\n        this.equipmentId = e.uid;\r\n        this.$refs.popup7.open();\r\n        this.$refs.popup4.close();\r\n        this.getEquipmentDetail();\r\n      },\r\n      //确认装备补充\r\n      async isSurebc() {\r\n        const data = {\r\n          uid: this.equipmentId,\r\n          expire_date: this.formData.expire_date,\r\n          maintenance_date: this.formData.maintenance_date,\r\n          count: this.formData.count,\r\n          rfid_code: this.formData.rfid_code,\r\n        };\r\n        try {\r\n          const res = await equipmentAdd(data);\r\n          if (res.code === 0) {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: '补充成功',\r\n              duration: 1000,\r\n            });\r\n            this.$refs.popup7.close();\r\n          } else {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: res.msg,\r\n            });\r\n          }\r\n        } catch (err) {\r\n          uni.showToast({\r\n            icon: 'none',\r\n            title: err,\r\n          });\r\n        }\r\n      },\r\n      //领用时扫描\r\n      async buttonEdit1(e) {\r\n        this.lyUid = e.uid;\r\n        this.$refs.popup1.close();\r\n        this.$refs.popup8.open();\r\n      },\r\n      //领用时确认填入rfid编码\r\n      async isSurely() {\r\n        try {\r\n          const res = await receiveCheck({\r\n            uid: this.lyUid,\r\n            rfid_code: this.formData1.rfid_code[0],\r\n          });\r\n          if (res.code === 0) {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: '检测成功',\r\n              duration: 1000,\r\n            });\r\n            this.receives = res.data;\r\n            this.$refs.popup8.close();\r\n            this.$refs.popup5.open();\r\n          } else {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: res.msg,\r\n            });\r\n          }\r\n        } catch (err) {\r\n          uni.showToast({\r\n            icon: 'none',\r\n            title: err,\r\n          });\r\n        }\r\n      },\r\n      //点击确认领用\r\n      async isSure() {\r\n        //例如三包纸巾，items传得长度就为几个,例如装备明细里有一个装备项，数组长度就为1\r\n        const items = [\r\n          {\r\n            uid: this.receives.uid,\r\n            rfid_code: this.formData1.rfid_code,\r\n          },\r\n        ];\r\n        const data = {\r\n          uid: this.lyUid,\r\n          items: items,\r\n        };\r\n        try {\r\n          const res = await receiveConfirm(data);\r\n          if (res.code === 0) {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: '领用成功',\r\n              duration: 1000,\r\n            });\r\n            this.$refs.popup5.close();\r\n          } else {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: res.msg,\r\n            });\r\n          }\r\n        } catch (err) {\r\n          uni.showToast({\r\n            icon: 'none',\r\n            title: err,\r\n          });\r\n        }\r\n      },\r\n      //点击归还\r\n      async buttonEdit3(e) {\r\n        this.$refs.popup9.open();\r\n        this.$refs.popup3.close();\r\n        this.ghUid = e.uid;\r\n      },\r\n      async isSuregh() {\r\n        try {\r\n          const res = await returnCheck({\r\n            uid: this.ghUid,\r\n            rfid_code: this.formData2.rfid_code,\r\n          });\r\n          if (res.code === 0) {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: '检测成功',\r\n              duration: 1000,\r\n            });\r\n            this.ghReturn = res.data;\r\n            this.$refs.popup9.close();\r\n            this.$refs.popup6.open();\r\n          } else {\r\n            uni.showToast({\r\n              icon: 'none',\r\n              title: res.msg,\r\n            });\r\n          }\r\n        } catch (err) {\r\n          uni.showToast({\r\n            icon: 'none',\r\n            title: err,\r\n          });\r\n        }\r\n      },\r\n      //点击确认\r\n      async isSureReturn() {\r\n        const i