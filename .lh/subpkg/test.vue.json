tns1\" @click=\"isSurely\">确认</view>\r\n        </view>\r\n      </uni-popup>\r\n      <uni-popup ref=\"popup9\" background-color=\"#fff\">\r\n        <view class=\"uni-container\">\r\n          <view class=\"ruku-title\">归还装备</view>\r\n          <div style=\"width: 100%; height: 1px\"></div>\r\n          <uni-forms\r\n            ref=\"baseForm\"\r\n            :modelValue=\"formData2\"\r\n            style=\"padding: 0 30rpx; margin-top: 30rpx\"\r\n          >\r\n            <uni-forms-item\r\n              label=\"RFID编号\"\r\n              name=\"equimentName\"\r\n              required\r\n              label-width=\"90\"\r\n            >\r\n              <uni-easyinput\r\n                v-model=\"formData2.rfid_code\"\r\n                placeholder=\"请输入RFID编号\"\r\n                :clearable=\"false\"\r\n              />\r\n            </uni-forms-item>\r\n          </uni-forms>\r\n          <view class=\"btns1\" @click=\"isSuregh\">确认</view>\r\n        </view>\r\n      </uni-popup>\r\n      <uni-popup ref=\"popup10\" background-color=\"#fff\">\r\n        <view class=\"uni-container\">\r\n          <view class=\"ruku-title\">装备详情</view>\r\n          <div style=\"width: 100%; height: 1px\"></div>\r\n          <uni-forms\r\n            ref=\"baseForm\"\r\n            :modelValue=\"formData2\"\r\n            style=\"padding: 0 30rpx; margin-top: 30rpx\"\r\n          >\r\n            <uni-forms-item\r\n              label=\"RFID编号\"\r\n              name=\"equimentName\"\r\n              required\r\n              label-width=\"90\"\r\n            >\r\n              <uni-easyinput\r\n                v-model=\"formData2.rfid_code\"\r\n                placeholder=\"请输入RFID编号\"\r\n                :clearable=\"false\"\r\n              />\r\n            </uni-forms-item>\r\n          </uni-forms>\r\n          <view class=\"btns1\" @click=\"iszbcheck\">确认</view>\r\n        </view>\r\n      </uni-popup>\r\n      <uni-popup ref=\"popup11\" background-color=\"#fff\">\r\n    