dding: 30rpx\"\r\n          >\r\n            <uni-forms-item label=\"名称\" name=\"name\" required label-width=\"90\">\r\n              <uni-easyinput\r\n                type=\"text\"\r\n                v-model=\"receives.name\"\r\n                :clearable=\"false\"\r\n                :disabled=\"true\"\r\n              />\r\n            </uni-forms-item>\r\n            <uni-forms-item label=\"规格\" name=\"spec\" required label-width=\"90\">\r\n              <uni-easyinput\r\n                type=\"text\"\r\n                v-model=\"receives.spec\"\r\n                :clearable=\"false\"\r\n                :disabled=\"true\"\r\n              />\r\n            </uni-forms-item>\r\n          </uni-forms>\r\n          <view class=\"btns1\" @click=\"isSure\">确认</view>\r\n        </view>\r\n      </uni-popup>\r\n      <uni-popup ref=\"popup6\" background-color=\"#fff\">\r\n        <view class=\"uni-container\">\r\n          <view class=\"ruku-title\">确认归还</view>\r\n          <uni-forms\r\n            ref=\"baseFormly\"\r\n            :modelValue=\"ghReturn\"\r\n            style=\"padding: 30rpx\"\r\n          >\r\n            <uni-forms-item label=\"名称\" name=\"name\" required label-width=\"90\">\r\n              <uni-easyinput\r\n                type=\"text\"\r\n                v-model=\"ghReturn.name\"\r\n                :clearable=\"false\"\r\n                :disabled=\"true\"\r\n              />\r\n            </uni-forms-item>\r\n            <uni-forms-item label=\"规格\" name=\"spec\" required label-width=\"90\">\r\n              <uni-easyinput\r\n                type=\"text\"\r\n                v-model=\"ghReturn.spec\"\r\n                :clearable=\"false\"\r\n                :disabled=\"true\"\r\n              />\r\n            </uni-forms-item>\r\n          </uni-forms>\r\n          <view class=\"btns1\" @click=\"isSureReturn\">确认</view>\r\n        </view>\r\n      </uni-popup>\r\n      <uni-popup ref=\"popup7\" background-color=\"#fff\">\r\n        <view clas